[Unit]
Description=File Upload Resource Site
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/file_upload
EnvironmentFile=/opt/file_upload/.env
ExecStart=/opt/file_upload/venv/bin/gunicorn --workers 2 --bind 127.0.0.1:8080 wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
